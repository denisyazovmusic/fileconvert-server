# Скопируй этот файл в .env для локального запуска
# На Railway эти переменные добавляются через интерфейс (не через файл)

# Твой ключ от ConvertAPI — меняй здесь без обновления расширения
CONVERTAPI_SECRET=your_convertapi_secret_here

# Секрет для проверки webhook от Prodamus (найди в настройках Prodamus)
PRODAMUS_SECRET=your_prodamus_secret_here

# Порт сервера (Railway подставляет автоматически)
PORT=3000

# Максимальный размер файла в МБ
MAX_FILE_MB=200
